class Solution {

    // Function to reverse a part of the array
    public static void reverse(int[] arr, int start, int end) {

        while (start < end) {
            int temp = arr[start];
            arr[start] = arr[end];
            arr[end] = temp;

            start++;
            end--;
        }
    }

    public static void shiftBy3(int[] arr) {

        int n = arr.length;
        int k = 3;

        // If k is greater than array size
        k = k % n;

        // Step 1
        reverse(arr, 0, n - 1);

        // Step 2
        reverse(arr, 0, k - 1);

        // Step 3
        reverse(arr, k, n - 1);

        // Print
        for (int x : arr) {
            System.out.print(x + " ");
        }
    }

    public static void main(String[] args) {

        int[] arr = {1, 2, 3, 4, 5};

        shiftBy3(arr);
    }
}
